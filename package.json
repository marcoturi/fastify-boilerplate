{
  "name": "fastify-boilerplate",
  "version": "2.6.0",
  "description": "A Fastify template that follows the Clean Architecture principles and encourages established practices.",
  "author": "Marco Turi <marco.turi@hotmail.it>",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#tests/*": "./tests/*"
  },
  "scripts": {
    "create:env": "node -e \"require('fs').copyFileSync('.env.example', '.env', require('fs').constants.COPYFILE_EXCL)\"",
    "start": "node --env-file=.env --import ./src/instrumentation.ts --watch src/index.ts | pino-pretty -clSt",
    "start:prod": "node --env-file=.env --import ./src/instrumentation.ts ./src/index.ts",
    "test": "pnpm test:unit",
    "test:coverage": "c8 node --test src/**/*.spec.ts",
    "test:unit": "node --test src/**/*.spec.ts",
    "test:e2e": "FASTIFY_AUTOLOAD_TYPESCRIPT=1 cucumber-js --exit",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "type:check": "tsc --noEmit",
    "check": "biome check && tsc --noEmit",
    "check:fix": "biome check --write && tsc --noEmit",
    "db": "dbmate h",
    "db:create-migration": "dbmate new",
    "db:migrate": "dbmate -e DBMATE_DATABASE_URL --no-dump-schema up",
    "db:create-seed": "dbmate -e DBMATE_DATABASE_URL -d ./db/seeds/ new",
    "db:seed": "dbmate -e DBMATE_DATABASE_URL -d ./db/seeds/ up",
    "db:seed:users": "k6 run ./tests/user/create-user/create-user.k6.ts",
    "generate:types": "bash scripts/generate-types.sh",
    "deps:validate": "depcruise src --config .dependency-cruiser.cjs --output-type err-long",
    "deps:graph": "depcruise src --include-only \"^src\" --config --output-type dot | dot -T svg > doc/dependency-graph.svg",
    "postinstall": "husky",
    "semantic-release": "semantic-release"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.17.0",
  "dependencies": {
    "@fastify/autoload": "6.4.0",
    "@fastify/awilix": "8.2.0",
    "@fastify/cors": "11.3.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/otel": "0.20.1",
    "@fastify/request-context": "7.0.0",
    "@fastify/swagger": "9.8.1",
    "@fastify/swagger-ui": "6.1.0",
    "@fastify/type-provider-typebox": "6.1.0",
    "@fastify/under-pressure": "9.1.0",
    "@graphql-tools/load-files": "7.0.1",
    "@graphql-tools/merge": "9.2.2",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/instrumentation": "0.221.0",
    "@opentelemetry/instrumentation-http": "0.221.0",
    "@opentelemetry/sdk-node": "0.221.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "awilix": "13.0.5",
    "env-schema": "7.0.0",
    "fastify": "5.10.0",
    "fastify-plugin": "6.0.0",
    "graphql": "16.14.2",
    "mercurius": "16.10.0",
    "postgres": "3.4.9",
    "typebox": "1.3.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@cucumber/cucumber": "13.2.0",
    "@cucumber/html-formatter": "24.1.0",
    "@cucumber/messages": "34.2.0",
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/typescript": "6.1.0",
    "@semantic-release/changelog": "7.0.0",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "11.0.1",
    "@semantic-release/github": "12.0.9",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@types/k6": "2.0.1",
    "@types/node": "26.1.1",
    "c8": "12.0.0",
    "dbmate": "2.34.1",
    "dependency-cruiser": "18.1.0",
    "husky": "9.1.7",
    "openapi-typescript": "7.13.0",
    "pino-pretty": "13.1.3",
    "semantic-release": "25.0.8",
    "typescript": "6.0.3"
  },
  "keywords": [
    "fastify",
    "domain-driven-design",
    "functional-programming",
    "vertical-slice-architecture",
    "cucumber",
    "clean-architecture",
    "typescript",
    "template",
    "boilerplate"
  ]
}
